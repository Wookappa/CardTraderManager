{
  "version": "2.0",
  "extensions": {
    "queues": {
      "batchSize": 1,
      "maxConcurrentCalls": 1,
      "newBatchThreshold": 0,
      "visibilityTimeout": "00:05:00",
      "maxPollingInterval": "00:02:30"
    }
  },
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      },
      "enableLiveMetricsFilters": true
    },
    "logLevel": {
      "Default": "Warning",
      "CardTraderManager.Operations.Services": "Information",
      "Function": "Information",
      "Host.Results": "Warning",
      "Host.Aggregator": "Warning",
      "Host.Startup": "Warning",
      "Custom": "Information",
      "Azure.Core": "Error"
    }
  }
}